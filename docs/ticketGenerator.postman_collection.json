{
  "info": {
    "name": "ticketGenerator API",
    "description": "Colección completa para probar el backend de ticketGenerator. Importa también el environment 'ticketGenerator ENV'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user', () => pm.expect(pm.response.json()).to.have.property('user'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has token', () => pm.expect(json).to.have.property('token'));",
                  "pm.collectionVariables.set('token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register — email duplicado (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 409', () => pm.response.to.have.status(409));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login — credenciales inválidas (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dev@example.com\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login — validación Zod (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets", "host": ["{{base_url}}"], "path": ["tickets"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has tickets array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('tickets');",
                  "  pm.expect(json.tickets).to.be.an('array');",
                  "});",
                  "const tickets = pm.response.json().tickets;",
                  "if (tickets.length > 0) {",
                  "  pm.collectionVariables.set('ticket_id', tickets[0].id);",
                  "  pm.collectionVariables.set('ticket_key', tickets[0].key);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/{{ticket_id}}", "host": ["{{base_url}}"], "path": ["tickets", "{{ticket_id}}"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has ticket', () => pm.expect(pm.response.json()).to.have.property('ticket'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Ticket by ID — no encontrado (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/INVALID-999", "host": ["{{base_url}}"], "path": ["tickets", "INVALID-999"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Search Tickets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/tickets/search?q=bug",
              "host": ["{{base_url}}"],
              "path": ["tickets", "search"],
              "query": [{ "key": "q", "value": "bug" }]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has tickets array', () => pm.expect(pm.response.json()).to.have.property('tickets'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Search Tickets — sin query (400)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tickets/search", "host": ["{{base_url}}"], "path": ["tickets", "search"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Tickets — sin token (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/tickets", "host": ["{{base_url}}"], "path": ["tickets"] }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Context",
      "item": [
        {
          "name": "Generate context.md",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/context", "host": ["{{base_url}}"], "path": ["context"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketIds\": [\"{{ticket_id}}\"]\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has content string', () => {",
                  "  pm.expect(json).to.have.property('content');",
                  "  pm.expect(json.content).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Generate context.md — ticket inexistente (404)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
